# Google Drive API Configuration
# Get your API key from: https://console.cloud.google.com/apis/credentials
GOOGLE_API_KEY=AIzaSyD4e5oEGc7fbHdWOCQt-Fdumh_Qtv4XhvQ

# Cloudinary Configuration (Optional - for owner photo uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Server Configuration
PORT=3000

# Instructions:
# 1. Copy this file to .env
# 2. Replace the placeholder values with your actual credentials
# 3. Never commit .env file to version control

# How to get Google API Key:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project or select existing one
# 3. Enable "Google Drive API"
# 4. Go to Credentials > Create Credentials > API Key
# 5. Restrict the API key to Google Drive API only (recommended)
# 6. Copy the API key and paste it above

# Important: Make sure your Google Drive folders are set to "Anyone with the link can view"
